+"""Command-line interface for aml_risk."""
+
+from __future__ import annotations
+
+import argparse
+
+from .pipeline import Transaction, score_transaction
+from .version import __version__
+
+
+def _build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(prog="aml-risk", description="AML/BSA risk helper")
+    parser.add_argument("--version", action="store_true", help="Print version and exit")
+    parser.add_argument("--amount", type=float, default=0.0, help="Transaction amount in USD")
+    parser.add_argument("--cross-border", action="store_true", help="Mark transaction as cross-border")
+    parser.add_argument("--high-risk-jurisdiction", action="store_true", help="Mark transaction as high-risk jurisdiction")
+    return parser
+
+
+def main() -> None:
+    parser = _build_parser()
+    args = parser.parse_args()
+
+    if args.version:
+        print(__version__)
+        return
+
+    txn = Transaction(
+        amount_usd=args.amount,
+        cross_border=args.cross_border,
+        high_risk_jurisdiction=args.high_risk_jurisdiction,
+    )
+    print(f"risk_score={score_transaction(txn):.1f}")
+
+
+if __name__ == "__main__":
+    main()
