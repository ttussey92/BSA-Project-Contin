+"""Simple AML/BSA research pipeline helpers."""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Iterable
+
+
+@dataclass(frozen=True)
+class Transaction:
+    """Basic transaction record used for a simple risk score."""
+
+    amount_usd: float
+    cross_border: bool = False
+    high_risk_jurisdiction: bool = False
+
+
+def score_transaction(txn: Transaction) -> float:
+    """Return a lightweight heuristic risk score from 0-100."""
+
+    score = 5.0
+
+    if txn.amount_usd >= 10000:
+        score += 25
+    elif txn.amount_usd >= 3000:
+        score += 10
+
+    if txn.cross_border:
+        score += 20
+
+    if txn.high_risk_jurisdiction:
+        score += 35
+
+    return min(score, 100.0)
+
+
+def score_batch(transactions: Iterable[Transaction]) -> list[float]:
+    """Score each transaction in a batch."""
+
+    return [score_transaction(txn) for txn in transactions]
